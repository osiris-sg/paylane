    "utils": "/Users/guru/lib/utils",
    "ui": "/Users/guru/components/ui",
    "lib": "/Users/guru/lib",
    "hooks": "/Users/guru/hooks"
  },
  "menuColor": "default",
  "menuAccent": "subtle",
  "registries": {}
}
