generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id        String   @id @default(cuid())
  clerkOrgId String? @unique
  name      String
  email     String?
  phone     String?
  address   String?
  module    CompanyModule?
  onboarded Boolean  @default(false)
  isStub    Boolean  @default(false)  // Auto-created placeholder for vendors discovered via email ingestion; not user-facing
  sendingPlan    SendingPlan @default(LOCKED)
  trialStartedAt DateTime?
  trialEndsAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  customers     Customer[]
  suppliers     Supplier[]
  linkedFrom    Customer[]   @relation("LinkedCompany") // other companies that added us as their customer
  linkedAsSupplierFor Supplier[] @relation("SupplierLinkedCompany")
  sentInvoices  Invoice[] @relation("SentInvoices")
  receivedInvoices Invoice[] @relation("ReceivedInvoices")
  sentInvitations Invitation[]
  sentStatements     Statement[] @relation("SentStatements")
  receivedStatements Statement[] @relation("ReceivedStatements")
  emailIntegration   EmailIntegration?
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String
  name      String?
  role      UserRole @default(USER)
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  whatsappNumber String?  // E.164 format, e.g. +6591234567
  whatsappOptIn  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdInvoices Invoice[]
  notifications   Notification[]
}

model Customer {
  id              String   @id @default(cuid())
  name            String
  email           String?
  phone           String?
  address         String?
  company         String?    // Display name of the customer's company
  companyId       String
  owner           Company  @relation(fields: [companyId], references: [id])
  linkedCompanyId String?
  linkedCompany   Company? @relation("LinkedCompany", fields: [linkedCompanyId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  invoices  Invoice[]
  statement Statement?
}

model Supplier {
  id              String   @id @default(cuid())
  name            String              // Contact name (legacy / required)
  email           String?
  phone           String?
  address         String?
  company         String?             // Display name of the supplier's company
  companyId       String              // The company that "owns" this supplier record (the receiver)
  owner           Company  @relation(fields: [companyId], references: [id])
  linkedCompanyId String?             // The supplier's actual Company on PayLane (set when they're a real PayLane company that has invoiced us)
  linkedCompany   Company? @relation("SupplierLinkedCompany", fields: [linkedCompanyId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([companyId, linkedCompanyId])
}

model Invoice {
  id             String        @id @default(cuid())
  invoiceNumber  String
  reference      String?
  invoicedDate   DateTime
  dueDate        DateTime
  paymentTerms   Int           @default(30) // days
  amount         Decimal       @db.Decimal(12, 2)
  currency       String        @default("SGD")
  routingStatus  RoutingStatus @default(PENDING)
  invoiceStatus  InvoiceStatus @default(DRAFT)
  source         InvoiceSource @default(MANUAL)
  expectedPaymentDate DateTime?  // Receiver's promised payment date
  fromAddress    String?
  toAddress      String?
  description    String?
  fileUrl        String?
  config         Json?
  pinned         Boolean       @default(false)

  customerId     String?
  customer       Customer?     @relation(fields: [customerId], references: [id])

  senderCompanyId   String
  senderCompany     Company   @relation("SentInvoices", fields: [senderCompanyId], references: [id])

  receiverCompanyId String?
  receiverCompany   Company?  @relation("ReceivedInvoices", fields: [receiverCompanyId], references: [id])

  createdById    String?
  createdBy      User?         @relation(fields: [createdById], references: [id], onDelete: SetNull)

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  sentAt         DateTime?

  items          InvoiceItem[]
  notifications  Notification[]
  timelineItems  TimelineItem[]
  ingestedEmail  IngestedEmail?

  subtotal       Decimal       @default(0) @db.Decimal(12, 2)
  taxRate        Decimal       @default(9) @db.Decimal(5, 2)
  taxAmount      Decimal       @default(0) @db.Decimal(12, 2)
  notes          String?

  @@unique([invoiceNumber, senderCompanyId])
}

model EmailIntegration {
  id             String   @id @default(cuid())
  companyId      String   @unique
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Per-company plus-address token. The user forwards invoices to
  // `<CLOUDMAILIN_INBOUND_ADDRESS_LOCAL>+<inboundToken>@cloudmailin.net`
  // and the webhook resolves the token back to this company.
  inboundToken   String   @unique

  // Phase 2 — Gmail OAuth fields (kept null in Phase 1, forwarding-only setup).
  provider       EmailProvider?
  providerEmail  String?
  refreshToken   String?  // encrypted at rest before storing
  gmailFilterId  String?

  status         EmailIntegrationStatus @default(ACTIVE)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  ingestedEmails IngestedEmail[]
}

model IngestedEmail {
  id                  String   @id @default(cuid())
  emailIntegrationId  String
  emailIntegration    EmailIntegration @relation(fields: [emailIntegrationId], references: [id], onDelete: Cascade)

  fromAddress         String
  subject             String?
  messageId           String?  @unique  // RFC 5322 Message-ID for dedup
  receivedAt          DateTime @default(now())

  status              IngestedEmailStatus  @default(RECEIVED)
  failureReason       String?

  // Stored for CONFIRMATION emails so we can render the link/code in-app.
  plainBody           String?  @db.Text
  htmlBody            String?  @db.Text
  confirmationLink    String?
  confirmationCode    String?

  invoiceId           String?  @unique
  invoice             Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([emailIntegrationId])
}

enum InvoiceSource {
  MANUAL
  EMAIL_FORWARD
}

enum EmailProvider {
  GMAIL
  OUTLOOK
}

enum EmailIntegrationStatus {
  ACTIVE
  PAUSED
  BROKEN
}

enum IngestedEmailStatus {
  RECEIVED       // just arrived, queued for parsing
  PARSED         // AI extracted invoice + Invoice row created
  IGNORED        // AI said this isn't an invoice / no PDF attached
  FAILED         // parser error
  CONFIRMATION   // Gmail/Outlook forwarding-verification email; link/code shown in UI
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Decimal  @db.Decimal(12, 2)
  unitPrice   Decimal  @db.Decimal(12, 2)
  amount      Decimal  @db.Decimal(12, 2)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Notification {
  id        String           @id @default(cuid())
  message   String
  read      Boolean          @default(false)
  type      NotificationType @default(GENERAL)
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoiceId String?
  invoice   Invoice?         @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  statementId String?
  statement   Statement?     @relation(fields: [statementId], references: [id], onDelete: SetNull)
  createdAt DateTime         @default(now())
}

model TimelineItem {
  id        String   @id @default(cuid())
  message   String
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Statement {
  id                String    @id @default(cuid())
  senderCompanyId   String
  senderCompany     Company   @relation("SentStatements", fields: [senderCompanyId], references: [id])
  customerId        String
  customer          Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  receiverCompanyId String?
  receiverCompany   Company?  @relation("ReceivedStatements", fields: [receiverCompanyId], references: [id])
  fileUrl           String    @db.Text   // data URL or external URL — same convention as Invoice.fileUrl
  fileName          String
  fileType          String
  notes             String?
  sentAt            DateTime  @default(now())
  viewedAt          DateTime?

  notifications     Notification[]

  @@unique([customerId])               // latest-only — a new SOA replaces the previous one
  @@index([senderCompanyId])
  @@index([receiverCompanyId])
}

model PushSubscription {
  id        String   @id @default(cuid())
  clerkId   String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clerkId])
}

enum CompanyModule {
  RECEIVE  // Company A — receives invoices from suppliers, adds suppliers
  SEND     // Suppliers — sends invoices to their customers
  BOTH     // Can both send and receive
}

enum SendingPlan {
  LOCKED   // Never trialed; SEND features hidden behind trial CTA
  TRIAL    // Inside 14-day window; full SEND access
  EXPIRED  // Trial ended; SEND read-only, awaiting upgrade
  PAID     // Direct sale or post-Airwallex; full SEND access, no expiry
}

enum UserRole {
  ADMIN
  USER
}

enum RoutingStatus {
  PENDING
  ACKNOWLEDGED
  FAILED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PENDING_APPROVAL  // Receiver claims they paid, waiting for sender to confirm
  PAID
  OVERDUE
  CANCELLED
}

model Invitation {
  id              String           @id @default(cuid())
  email           String
  companyName     String           // The name they provided for the supplier
  status          InvitationStatus @default(PENDING)
  senderCompanyId String
  senderCompany   Company          @relation(fields: [senderCompanyId], references: [id])
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([email, senderCompanyId])
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

enum NotificationType {
  GENERAL
  INVOICE_RECEIVED
  PAYMENT_DUE_SOON
  PAYMENT_OVERDUE
  INVOICE_PAID
  INVOICE_ACKNOWLEDGED
  STATEMENT_RECEIVED
}

model FeatureFlag {
  key       String   @id
  enabled   Boolean  @default(false)
  updatedAt DateTime @updatedAt
}
